# VacayScout Affiliate IDs
# Copy this to .env and fill in your real affiliate IDs.
# Without these, links use demo/test IDs — they work but won't track commissions.

# Booking.com Affiliate ID (appended as ?aid=... to hotel search links)
VITE_BOOKING_AID=your_booking_affiliate_id_here

# Kayak affiliate tracking ID (appended as ?ai=... to flight search links)
VITE_KAYAK_AFFILIATE=your_kayak_affiliate_id_here
